# --- Server ---
# NODE_ENV=production disables demo seeding and the dev docs UI
NODE_ENV=development
PORT=3000
# Internal Prometheus listener — never published by Compose or the proxy
METRICS_PORT=9464
# Metrics bind address: loopback in dev; the container image sets 0.0.0.0 so
# the org Prometheus can scrape over the internal network
# METRICS_HOST=127.0.0.1
PUBLIC_BASE_URL=http://localhost:3000
# Known reverse-proxy hop count; per-IP rate limits depend on it (0 in dev)
TRUST_PROXY_HOPS=0
LOG_LEVEL=info

# --- Storage (paths are created on boot if missing) ---
# The ./data defaults below are also the built-in defaults, and the container
# pins /data/... at the compose level — leave these commented out so a copied
# .env can never repoint a container off its volume.
# DATABASE_PATH=./data/app.sqlite
# BLOB_DIR=./data/blobs
# Nightly VACUUM INTO snapshots land here (newest 7 retained)
# SNAPSHOT_DIR=./data/snapshots

# --- Backups (compose `backup` profile; see litestream.yml) ---
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=

# --- Dev conveniences (never enable in production) ---
# Off by default so a fresh checkout goes through the first-boot setup page
# (create the first admin in the browser). Set to true if you'd rather boot
# straight into demo data (users for every role + sample cards).
SEED_DEMO_DATA=false
# Shared password for all demo users (12–128 chars); only used when
# SEED_DEMO_DATA=true, and refused outright in production mode. This is an
# obvious demo-only credential — every seeded role logs in with it
# (admin@demo.rivian-kanban.local etc.). Unset it for one-time random
# passwords printed at first boot instead.
SEED_DEMO_PASSWORD=demo-password-123

# --- Slack integration (optional; see docs/architecture/slack.md) ---
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_TEAM_ID=

# --- AI thread summarization (optional; provider-agnostic, see ADR-017) ---
SUMMARIZER_ENABLED=false
# anthropic | openai | google | openai-compatible (default anthropic)
SUMMARIZER_PROVIDER=anthropic
SUMMARIZER_MODEL=claude-haiku-4-5
SUMMARIZER_API_KEY=
# Optional endpoint override; required for openai-compatible
# (e.g. https://integrate.api.nvidia.com/v1)
SUMMARIZER_BASE_URL=
