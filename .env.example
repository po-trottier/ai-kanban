# --- Server ---
# NODE_ENV=production disables demo seeding and the dev docs UI
NODE_ENV=development
PORT=3000
# Internal Prometheus listener — never published by Compose or the proxy
METRICS_PORT=9464
PUBLIC_BASE_URL=http://localhost:3000
# Known reverse-proxy hop count; per-IP rate limits depend on it (0 in dev)
TRUST_PROXY_HOPS=0
LOG_LEVEL=info

# --- Storage (paths are created on boot if missing) ---
DATABASE_PATH=./data/app.sqlite
BLOB_DIR=./data/blobs

# --- Dev conveniences (never enable in production) ---
SEED_DEMO_DATA=true

# --- Slack integration (optional; see docs/architecture/slack.md) ---
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_TEAM_ID=

# --- AI thread summarization (optional; see docs/architecture/slack.md) ---
SUMMARIZER_ENABLED=false
ANTHROPIC_API_KEY=
