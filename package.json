{
  "name": "rivian-kanban",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "e2e"
  ],
  "knip": {
    "workspaces": {
      "e2e": {
        "entry": [
          "scripts/prepare.mjs"
        ]
      }
    }
  },
  "scripts": {
    "setup": "npm rebuild --ignore-scripts=false --foreground-scripts better-sqlite3 argon2 && lefthook install",
    "dev": "concurrently -k -n server,web -c blue,green \"npm run dev -w @rivian-kanban/server\" \"npm run dev -w @rivian-kanban/web\"",
    "build": "npm run build -w @rivian-kanban/web && npm run build -w @rivian-kanban/server",
    "typecheck": "tsc -p packages/core && tsc -p packages/db && tsc -p packages/server && tsc -p packages/web && tsc -p e2e",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit --project web",
    "test:integration": "vitest run --project integration",
    "test:e2e": "npm run test -w e2e",
    "db:generate": "npm run generate -w @rivian-kanban/db",
    "db:migrate": "npm run migrate -w @rivian-kanban/db",
    "db:seed": "npm run seed -w @rivian-kanban/db",
    "db:studio": "npm run studio -w @rivian-kanban/db",
    "depcruise": "depcruise packages e2e --config .dependency-cruiser.cjs",
    "knip": "knip",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run depcruise && npm run knip && npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.23",
    "concurrently": "10.0.3",
    "dependency-cruiser": "18.1.0",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.10.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-testing-library": "7.16.2",
    "globals": "17.7.0",
    "knip": "6.27.0",
    "lefthook": "2.1.10",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
